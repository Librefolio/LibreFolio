# OpenRouter API Key for Aphra translation pipeline
# See README.md for setup instructions (OpenRouter BYOK + Google Gemini)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── LLM Models ──────────────────────────────────────────────
# Aphra uses 3 roles: writer (translate + refine), searcher (glossary lookup),
# critiquer (review translation). Each can use a different model.
#
# Priority: APHRA_WRITER > APHRA_MODEL > hardcoded default (gemini-2.5-flash)
#
# APHRA_MODEL sets all 3 roles at once (convenient shortcut).
# APHRA_WRITER / APHRA_SEARCHER / APHRA_CRITIQUER override individual roles.

# Shared model for all roles (comment out to use hardcoded default: google/gemini-2.5-flash)
# APHRA_MODEL=google/gemini-2.5-flash

# Per-role overrides (uncomment to use different models per role)
# APHRA_WRITER=google/gemini-2.5-flash
# APHRA_SEARCHER=google/gemini-2.5-flash
# APHRA_CRITIQUER=google/gemini-2.5-flash

# ── Web Search ──────────────────────────────────────────────
# Aphra's Step 2 (Search) uses OpenRouter's web search plugin to look up
# context for each term found in Step 1. This adds cost ($4/1000 results)
# and is slow. For technical docs with well-known terms, it's not needed.
# Set to true only if translating content with obscure cultural references.
APHRA_WEB_SEARCH=false
